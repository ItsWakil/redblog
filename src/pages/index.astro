---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">Fantasy &amp; Creative Writing</p>
				<h1>Tales, worlds, and the tools used to build them.</h1>
				<p class="dek">
					A record of stories in progress, games taking shape, ink on paper, and the
					marks left along the way.
				</p>
			</section>

			<div class="fleuron"><span></span></div>

			<section class="latest">
				<h2>Latest from the blog</h2>
				<div class="grid">
					{
						posts.map((post) => (
							<a class="card" href={`${base}blog/${post.id}/`}>
								<p class="card-date">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<h3>{post.data.title}</h3>
								<p class="card-desc">{post.data.description}</p>
								<span class="read-more">Read the tale &rarr;</span>
							</a>
						))
					}
				</div>
				<p class="all-posts"><a href={`${base}blog`}>View all posts &rarr;</a></p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		text-align: center;
		padding: 1em 0 0;
	}
	.hero h1 {
		font-style: italic;
		margin: 0.3em 0 0.5em;
	}
	.hero .dek {
		font-size: 1.1em;
		color: var(--parchment-dim);
		max-width: 540px;
		margin: 0 auto;
	}
	.latest h2 {
		text-align: center;
		font-size: 1.6em;
		margin-bottom: 1em;
	}
	.grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5em;
	}
	.card {
		display: flex;
		flex-direction: column;
		background: var(--navy);
		border: 1px solid var(--hairline);
		padding: 1.6em;
		text-decoration: none;
		position: relative;
		transition: border-color 0.2s ease, transform 0.2s ease;
	}
	.card:hover {
		border-color: var(--gold);
		transform: translateY(-3px);
	}
	.card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 14px;
		height: 14px;
		border-top: 1px solid var(--gold);
		border-left: 1px solid var(--gold);
		opacity: 0;
		transition: opacity 0.2s ease;
	}
	.card:hover::before {
		opacity: 1;
	}
	.card-date {
		font-family: var(--font-display);
		font-size: 0.65em;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--gold);
		margin: 0 0 0.6em;
	}
	.card h3 {
		font-size: 1.4em;
		margin-bottom: 0.4em;
	}
	.card-desc {
		color: var(--parchment-dim);
		font-size: 0.9em;
		flex-grow: 1;
	}
	.read-more {
		font-family: var(--font-display);
		font-size: 0.65em;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--gold-bright);
		margin-top: 1em;
	}
	.all-posts {
		text-align: center;
		margin-top: 2.5em;
		font-family: var(--font-display);
		font-size: 0.75em;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}
	@media (max-width: 860px) {
		.grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (max-width: 600px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
