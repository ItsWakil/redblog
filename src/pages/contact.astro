---
import Layout from '../layouts/PageLayout.astro';
---

<Layout
	title="Contact Me"
	description="Get in touch."
	eyebrow="Send a raven"
>
	<p>
		Whether it's about a project, a commission, or just to talk about fantasy worlds and the
		tools used to build them, feel free to reach out.
	</p>

	<div class="contact-links">
		<a class="contact-link" href="mailto:you@example.com">
			<span class="label">Email</span>
			<span class="value">you@example.com</span>
		</a>
		<a class="contact-link" href="https://instagram.com/yourhandle" target="_blank" rel="noopener">
			<span class="label">Instagram</span>
			<span class="value">@yourhandle</span>
		</a>
		<a class="contact-link" href="https://github.com/ItsWakil" target="_blank" rel="noopener">
			<span class="label">GitHub</span>
			<span class="value">ItsWakil</span>
		</a>
	</div>
</Layout>

<style>
	.contact-links {
		display: flex;
		flex-direction: column;
		gap: 1px;
		margin-top: 2em;
		border-top: 1px solid var(--hairline);
	}
	.contact-link {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding: 1.1em 0.2em;
		border-bottom: 1px solid var(--hairline);
		text-decoration: none;
		transition: padding-left 0.2s ease;
	}
	.contact-link:hover {
		padding-left: 0.6em;
	}
	.label {
		font-family: var(--font-display);
		font-size: 0.85em;
		letter-spacing: 0.03em;
		color: var(--gold);
	}
	.value {
		font-family: var(--font-headline);
		font-size: 1.2em;
		color: var(--parchment);
	}
	.contact-link:hover .value {
		color: var(--gold-bright);
	}
</style>
