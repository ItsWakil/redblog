---
import Layout from '../layouts/PageLayout.astro';
---

<Layout
	title="Contact Me"
	description="Get in touch."
	eyebrow="Send a raven"
>
	<p>
		Whether it's about a project, a commission, or just to talk about fantasy worlds and the
		tools used to build them, feel free to reach out.
	</p>

	<form id="contact-form" class="contact-form">

		<input type="hidden" name="access_key" value="a4fd3920-5621-480b-9b28-b3e737b8956e" />
		<input type="checkbox" name="botcheck" class="hidden-field" tabindex="-1" autocomplete="off" />

		<label>
			<span class="label">Name</span>
			<input type="text" name="name" required />
		</label>
		<label>
			<span class="label">Your email</span>
			<input type="email" name="email" required />
		</label>
		<label>
			<span class="label">Message</span>
			<textarea name="message" rows="6" required></textarea>
		</label>

		<button type="submit">Send</button>
		<p id="form-status" class="form-status" role="status"></p>
	</form>

	<div class="fleuron"><span></span></div>

	<div class="contact-links">
		<a class="contact-link" href="https://instagram.com/yourhandle" target="_blank" rel="noopener">
			<span class="label">Instagram</span>
			<span class="value">@yourhandle</span>
		</a>
		<a class="contact-link" href="https://github.com/ItsWakil" target="_blank" rel="noopener">
			<span class="label">GitHub</span>
			<span class="value">ItsWakil</span>
		</a>
	</div>
</Layout>

<style>
	.contact-form {
		display: flex;
		flex-direction: column;
		gap: 1.3em;
		margin: 2em 0;
	}
	.contact-form label {
		display: flex;
		flex-direction: column;
		gap: 0.5em;
	}
	.hidden-field {
		display: none;
	}
	.label {
		font-family: var(--font-display);
		font-size: 0.85em;
		letter-spacing: 0.03em;
		color: var(--gold);
	}
	.contact-form input[type='text'],
	.contact-form input[type='email'],
	.contact-form textarea {
		background: var(--navy);
		border: 1px solid var(--hairline);
		color: var(--parchment);
		font-family: var(--font-body);
		font-size: 1.05em;
		padding: 0.7em 0.9em;
	}
	.contact-form input:focus,
	.contact-form textarea:focus {
		outline: none;
		border-color: var(--gold);
	}
	.contact-form textarea {
		resize: vertical;
	}
	button[type='submit'] {
		align-self: flex-start;
		font-family: var(--font-display);
		font-size: 0.95em;
		letter-spacing: 0.03em;
		background: transparent;
		color: var(--gold);
		border: 1px solid var(--gold);
		padding: 0.7em 1.8em;
		cursor: pointer;
		transition: background 0.2s ease, color 0.2s ease;
	}
	button[type='submit']:hover {
		background: var(--gold);
		color: var(--ink);
	}
	button[type='submit']:disabled {
		opacity: 0.5;
		cursor: default;
	}
	.form-status {
		font-family: var(--font-display);
		font-size: 0.9em;
		margin: 0;
		min-height: 1.2em;
	}
	.form-status.success {
		color: var(--gold-bright);
	}
	.form-status.error {
		color: #c96a4a;
	}
	.contact-links {
		display: flex;
		flex-direction: column;
		gap: 1px;
		border-top: 1px solid var(--hairline);
	}
	.contact-link {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding: 1.1em 0.2em;
		border-bottom: 1px solid var(--hairline);
		text-decoration: none;
		transition: padding-left 0.2s ease;
	}
	.contact-link:hover {
		padding-left: 0.6em;
	}
	.value {
		font-family: var(--font-headline);
		font-size: 1.2em;
		color: var(--parchment);
	}
	.contact-link:hover .value {
		color: var(--gold-bright);
	}
</style>

<script>
	const form = document.getElementById('contact-form') as HTMLFormElement | null;
	const status = document.getElementById('form-status');

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const button = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
		if (button) button.disabled = true;
		if (status) {
			status.textContent = 'Sending...';
			status.className = 'form-status';
		}

		try {
			const response = await fetch('https://api.web3forms.com/submit', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
				body: JSON.stringify(Object.fromEntries(new FormData(form))),
			});
			const result = await response.json();

			if (result.success) {
				if (status) {
					status.textContent = 'Message sent — thank you.';
					status.className = 'form-status success';
				}
				form.reset();
			} else {
				throw new Error(result.message || 'Something went wrong.');
			}
		} catch (err) {
			if (status) {
				status.textContent = 'Could not send. Please try again in a moment.';
				status.className = 'form-status error';
			}
		} finally {
			if (button) button.disabled = false;
		}
	});
</script>
