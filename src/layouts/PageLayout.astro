---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description: string;
	eyebrow: string;
}

const { title, description, eyebrow } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-title">
				<p class="eyebrow">{eyebrow}</p>
				<h1>{title}</h1>
				<div class="fleuron"><span></span></div>
			</div>
			<div class="prose">
				<slot />
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-title {
		text-align: center;
		margin-bottom: 1em;
	}
	.page-title h1 {
		margin: 0.2em 0;
	}
</style>
