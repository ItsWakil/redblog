---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

export interface GalleryItem {
	title: string;
	meta?: string;
	description: string;
	link?: string;
}

interface Props {
	title: string;
	description: string;
	eyebrow: string;
	intro?: string;
	items: GalleryItem[];
}

const { title, description, eyebrow, intro, items } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main class="wide">
			<div class="page-title">
				<p class="eyebrow">{eyebrow}</p>
				<h1>{title}</h1>
				<div class="fleuron"><span></span></div>
				{intro && <p class="intro">{intro}</p>}
			</div>

			<div class="grid">
				{
					items.map((item) => {
						const Tag = item.link ? 'a' : 'div';
						return (
							<Tag class="card" {...(item.link ? { href: item.link } : {})}>
								{item.meta && <p class="card-meta">{item.meta}</p>}
								<h3>{item.title}</h3>
								<p class="card-desc">{item.description}</p>
							</Tag>
						);
					})
				}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.wide {
		width: 1080px;
	}
	.page-title {
		text-align: center;
		margin-bottom: 1em;
	}
	.page-title h1 {
		margin: 0.2em 0;
	}
	.intro {
		max-width: 560px;
		margin: 0 auto;
		color: var(--parchment-dim);
		font-size: 1.05em;
		text-align: center;
	}
	.grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5em;
		margin-top: 2em;
	}
	.card {
		display: block;
		background: var(--navy);
		border: 1px solid var(--hairline);
		padding: 1.6em;
		text-decoration: none;
		position: relative;
		transition: border-color 0.2s ease, transform 0.2s ease;
	}
	a.card:hover {
		border-color: var(--gold);
		transform: translateY(-3px);
	}
	.card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 14px;
		height: 14px;
		border-top: 1px solid var(--gold);
		border-left: 1px solid var(--gold);
		opacity: 0;
		transition: opacity 0.2s ease;
	}
	a.card:hover::before {
		opacity: 1;
	}
	.card-meta {
		font-family: var(--font-display);
		font-size: 0.8em;
		letter-spacing: 0.03em;
		color: var(--gold);
		margin: 0 0 0.6em;
	}
	.card h3 {
		font-size: 1.4em;
		margin-bottom: 0.4em;
		color: var(--parchment);
	}
	.card-desc {
		color: var(--parchment-dim);
		font-size: 0.9em;
		margin: 0;
	}
	@media (max-width: 860px) {
		.grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (max-width: 600px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
