---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a class="card" href={`${base}blog/${post.id}/`}>
	<div class="card-image">
		{
			post.data.heroImage ? (
				<Image src={post.data.heroImage} alt="" width={480} height={300} />
			) : (
				<div class="fallback">
					<span class="fallback-mark"></span>
				</div>
			)
		}
	</div>
	<div class="card-body">
		<p class="card-date">
			<FormattedDate date={post.data.pubDate} />
		</p>
		<h3>{post.data.title}</h3>
		<p class="card-desc">{post.data.description}</p>
		<span class="read-more">Read the tale &rarr;</span>
	</div>
</a>

<style>
	.card {
		display: flex;
		flex-direction: column;
		background: var(--navy);
		border: 1px solid var(--hairline);
		text-decoration: none;
		position: relative;
		overflow: hidden;
		transition: border-color 0.2s ease, transform 0.2s ease;
	}
	.card:hover {
		border-color: var(--gold);
		transform: translateY(-3px);
	}
	.card::after {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 14px;
		height: 14px;
		border-top: 1px solid var(--gold-bright);
		border-left: 1px solid var(--gold-bright);
		opacity: 0;
		transition: opacity 0.2s ease;
		z-index: 2;
	}
	.card:hover::after {
		opacity: 1;
	}
	.card-image {
		aspect-ratio: 8 / 5;
		overflow: hidden;
		position: relative;
		border-bottom: 1px solid var(--hairline);
	}
	.card-image::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, rgba(10, 10, 10, 0.15) 0%, rgba(15, 26, 46, 0.55) 100%);
		mix-blend-mode: multiply;
	}
	.card-image :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		filter: saturate(0.75) sepia(0.15);
		transition: transform 0.4s ease, filter 0.4s ease;
		border-radius: 0;
	}
	.card:hover .card-image :global(img) {
		transform: scale(1.05);
		filter: saturate(0.9) sepia(0.05);
	}
	.fallback {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		background: radial-gradient(circle, var(--navy-light) 0%, var(--navy) 75%);
	}
	.fallback-mark {
		width: 0.9em;
		height: 0.9em;
		border: 1px solid var(--gold);
		transform: rotate(45deg);
	}
	.card-body {
		display: flex;
		flex-direction: column;
		flex-grow: 1;
		padding: 1.4em 1.6em 1.6em;
	}
	.card-date {
		font-family: var(--font-display);
		font-size: 0.8em;
		letter-spacing: 0.03em;
		color: var(--gold);
		margin: 0 0 0.6em;
	}
	.card-body h3 {
		font-size: 1.4em;
		margin-bottom: 0.4em;
	}
	.card-desc {
		color: var(--parchment-dim);
		font-size: 0.9em;
		flex-grow: 1;
	}
	.read-more {
		font-family: var(--font-display);
		font-size: 0.8em;
		letter-spacing: 0.02em;
		color: var(--gold-bright);
		margin-top: 1em;
	}
</style>
