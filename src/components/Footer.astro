---
import { SITE_TITLE } from '../consts';

const today = new Date();
const base = import.meta.env.BASE_URL;
---

<footer>
	<div class="fleuron"><span></span></div>
	<p class="colophon">
		&copy; {today.getFullYear()} {SITE_TITLE}. Written by hand, published by starlight.
	</p>
	<p class="colophon-link"><a href={`${base}contact`}>Get in touch</a></p>
</footer>
<style>
	footer {
		padding: 1em 1em 4em;
		text-align: center;
		color: var(--parchment-dim);
	}
	footer .fleuron {
		max-width: 400px;
		margin: 0 auto;
	}
	.colophon {
		font-family: var(--font-display);
		font-size: 0.8em;
		letter-spacing: 0.03em;
		margin-bottom: 0.4em;
	}
	.colophon-link {
		font-family: var(--font-display);
		font-size: 0.8em;
		letter-spacing: 0.03em;
		margin: 0;
	}
	.colophon-link a {
		color: var(--gold);
	}
	.colophon-link a:hover {
		color: var(--gold-bright);
	}
</style>
