---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const base = import.meta.env.BASE_URL;
---

<header>
	<div class="wrap">
		<a class="site-title" href={base}>{SITE_TITLE}</a>
		<nav>
			<HeaderLink href={base}>Home</HeaderLink>
			<HeaderLink href={`${base}blog`}>Blog</HeaderLink>
			<HeaderLink href={`${base}games`}>Games</HeaderLink>
			<HeaderLink href={`${base}pens`}>Pens</HeaderLink>
			<HeaderLink href={`${base}tattoos`}>Tattoos</HeaderLink>
			<HeaderLink href={`${base}projects`}>Projects</HeaderLink>
			<HeaderLink href={`${base}about`}>About</HeaderLink>
			<HeaderLink href={`${base}contact`}>Contact</HeaderLink>
		</nav>
	</div>
</header>
<style>
	header {
		background: var(--ink);
		border-bottom: 1px solid var(--hairline);
		padding: 2.2em 1em 1.4em;
	}
	.wrap {
		max-width: 1080px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.2em;
	}
	.site-title {
		font-family: var(--font-display);
		font-size: 1.7em;
		font-weight: 600;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--gold);
		text-decoration: none;
	}
	.site-title:hover {
		color: var(--gold-bright);
	}
	nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		align-items: center;
		row-gap: 0.6em;
	}
	nav :global(a) {
		font-family: var(--font-display);
		font-size: 0.72em;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--parchment-dim);
		text-decoration: none;
		padding: 0.3em 0.9em;
		border-bottom: 1px solid transparent;
		transition: color 0.2s ease, border-color 0.2s ease;
	}
	nav :global(a):not(:last-child) {
		border-right: 1px solid var(--hairline);
	}
	nav :global(a:hover) {
		color: var(--gold-bright);
	}
	nav :global(a.active) {
		color: var(--gold);
		border-bottom-color: var(--gold);
	}
	@media (max-width: 640px) {
		nav :global(a) {
			padding: 0.3em 0.6em;
		}
	}
</style>
